# ─────────────────────────────────────────────────────────────────────────────
# uEvents backend — environment variables
# Copy to `.env` and fill in. On Render, set these under Environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
JWT_SECRET="a-long-random-string"

# Code that clubs must enter to create a CLUB account.
CLUB_INVITE_CODE="CSSA-CLUBS-2026"

# ── Email: Gmail SMTP (current) ──────────────────────────────────────────────
# Sends from your own Gmail with no domain to verify (~500 recipients/day).
# 1. Turn on 2-Step Verification on the Google account.
# 2. Create an app password: https://myaccount.google.com/apppasswords
# 3. Put the 16-char password below (spaces are fine, they're stripped).
GMAIL_USER="youraccount@gmail.com"
GMAIL_APP_PASSWORD="abcd efgh ijkl mnop"
# Optional display name and from-address (defaults to "uEvents" + GMAIL_USER).
EMAIL_FROM_NAME="uEvents"
# FROM_EMAIL="youraccount@gmail.com"   # only override if using a Gmail send-as alias

# ── Email: Resend (later — leave blank while using Gmail) ────────────────────
# When you switch: set RESEND_API_KEY + a FROM_EMAIL on a Resend-verified domain.
# If GMAIL_USER + GMAIL_APP_PASSWORD are set, they take priority over Resend.
# RESEND_API_KEY="re_..."
# FROM_EMAIL="noreply@yourverifieddomain.com"

# ── Cloudinary (image uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Optional (all have safe defaults) ────────────────────────────────────────
PORT="4000"
# NODE_ENV="production"                       # only "test" changes behavior
# Restrict signups to these domains (comma-separated). Unset = any email allowed.
# SCHOOL_EMAIL_DOMAINS="uottawa.ca"
# Allowed browser origins (comma-separated). Unset = allow all (fine for mobile).
# CORS_ORIGINS="https://app.example.com"
# Stable base URL for calendar (.ics) links. Falls back to the request host.
# PUBLIC_BASE_URL="https://ueventsapp.onrender.com"
# Enables auto image moderation. Unset = recap photos held as PENDING for review.
# IMAGE_MODERATION_PROVIDER=""
# Store links used in share text (have sensible defaults).
# APP_STORE_URL="https://apps.apple.com/app/uevents"
# PLAY_STORE_URL="https://play.google.com/store/apps/details?id=com.cssa.uevents"
# Shown in legal/contact copy.
# LEGAL_CONTACT_EMAIL="legal@example.com"

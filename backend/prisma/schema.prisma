generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  type          UserType
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  firstName     String?
  lastName      String?
  program       String?
  year          String?
  avatarUrl     String?
  clubName      String?
  slug          String?        @unique
  category      String?
  description   String?
  logoUrl       String?
  instagram     String?
  twitter       String?
  contactEmail  String?
  pushToken     String?
  pushNotifs    Boolean        @default(true)
  emailDigest   Boolean        @default(false)
  tokenVersion  Int            @default(0)
  emailVerified DateTime?
  // Club self-signup approval (null for students; clubs are PENDING until an admin approves)
  clubStatus          ClubStatus?
  clubRejectionReason String?
  // Per-user ICS calendar subscription token
  calendarToken String?        @unique
  bookmarks     Bookmark[]
  checkIns      CheckIn[]
  comments      Comment[]
  commentUpvotes CommentUpvote[]
  followedBy    Follow[]       @relation("ClubFollowers")
  follows       Follow[]       @relation("StudentFollows")
  likes         Like[]
  notifications Notification[]
  posts         Post[]
  rsvps         Rsvp[]
  waitlistEntries Waitlist[]
  postViews     PostView[]
  feedbacks     Feedback[]
  reports       Report[]
  passwordResets PasswordReset[]
  emailVerifications EmailVerification[]
  eventSeries   EventSeries[]
  interestFollows InterestFollow[]
  eventPhotos   EventPhoto[]
  eventRatings  EventRating[]
  blockedUsers  BlockedUser[] @relation("BlockerRelation")
  blockedBy     BlockedUser[] @relation("BlockedRelation")
  feedSignals   FeedSignal[]
}

model Post {
  id                String       @id @default(cuid())
  clubId            String
  type              PostType
  isDraft           Boolean      @default(true)
  publishAt         DateTime?
  locales           Json
  startAt           DateTime?
  endAt             DateTime?
  locationName      String?
  address           String?
  categories        String[]
  images            String[]     @default([])
  capacity          Int?
  freeFood          Boolean      @default(false)
  recapPrivate      Boolean      @default(false)
  isPinned          Boolean      @default(false)
  pollExpiresAt     DateTime?
  pollAllowMultiple Boolean      @default(false)
  seriesId          String?
  occurrenceDate    DateTime?
  hidden            Boolean      @default(false)  // moderation: hidden by admin, excluded from public feeds
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  series            EventSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  bookmarks         Bookmark[]
  checkIns          CheckIn[]
  comments          Comment[]
  likes             Like[]
  pollOptions       PollOption[]
  club              User         @relation(fields: [clubId], references: [id])
  rsvps             Rsvp[]
  waitlistEntries   Waitlist[]
  views             PostView[]
  recapPhotos       EventPhoto[]
  recapRatings      EventRating[]

  @@index([seriesId])
}

model EventPhoto {
  id        String            @id @default(cuid())
  postId    String
  userId    String
  url       String
  status    EventPhotoStatus  @default(PENDING)  // moderation: only APPROVED show publicly
  createdAt DateTime          @default(now())
  post      Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id])

  @@index([postId])
  @@index([postId, status])
}

enum EventPhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

model EventRating {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  rating    Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
}

model PollOption {
  id     String     @id @default(cuid())
  postId String
  textEn String
  textFr String?
  post   Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  votes  PollVote[]
}

model PollVote {
  userId    String
  optionId  String
  createdAt DateTime   @default(now())
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([userId, optionId])
}

model Follow {
  userId    String
  clubId    String
  notifPref NotifPref @default(ALL)
  createdAt DateTime  @default(now())
  club      User      @relation("ClubFollowers", fields: [clubId], references: [id])
  user      User      @relation("StudentFollows", fields: [userId], references: [id])

  @@id([userId, clubId])
}

model Rsvp {
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, postId])
}

model Waitlist {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId, createdAt])
}

model CheckIn {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  checkedAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, postId])
}

model Bookmark {
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, postId])
}

model PostView {
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, postId])
}

model Comment {
  id        String    @id @default(cuid())
  userId    String
  postId    String
  content   String
  parentId  String?
  upvotes   Int       @default(0)
  hidden    Boolean   @default(false)  // moderation: hidden by admin, excluded from public views
  createdAt DateTime  @default(now())
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  upvotedBy CommentUpvote[]
}

// Per-user like on a comment. `Comment.upvotes` stays as the denormalized count
// (kept in sync on toggle) for cheap ordering; this table tracks WHO liked it.
model CommentUpvote {
  userId    String
  commentId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      NotifType
  title     String
  body      String
  isRead    Boolean   @default(false)
  metadata  Json?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

enum UserType {
  STUDENT
  CLUB
  ADMIN
}

enum ClubStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PostType {
  EVENT
  ANNOUNCEMENT
  UPDATE
  POLL
}

enum NotifPref {
  ALL
  EVENTS
  NONE
}

enum NotifType {
  EVENT
  POST
  REMINDER
  LIKE
  FOLLOW
  WAITLIST_PROMOTED
  DIGEST
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterestFollow {
  id        String   @id @default(cuid())
  userId    String
  category  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([category])
}

model EventSeries {
  id         String         @id @default(cuid())
  clubId     String
  freq       RecurrenceFreq
  interval   Int            @default(1)
  byWeekday  Int[]          @default([])
  startDate  DateTime
  endDate    DateTime?
  count      Int?
  template   Json
  createdAt  DateTime       @default(now())
  club       User           @relation(fields: [clubId], references: [id])
  posts      Post[]

  @@index([clubId])
}

enum RecurrenceFreq {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model Feedback {
  id           String       @id @default(cuid())
  type         FeedbackType
  message      String
  imageUrl     String?
  contactEmail String?
  userId       String?
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
}

enum FeedbackType {
  BUG_REPORT
  FEATURE_REQUEST
}

// "Show less like this" signals from the For You feed. Doubles as structured
// tester feedback (queryable by category/club) and tunes the ranker: matching
// clubs/categories are down-ranked and the exact post is suppressed.
model FeedSignal {
  id         String   @id @default(cuid())
  userId     String
  postId     String?
  clubId     String?
  categories String[] @default([])
  reason     String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Report {
  id           String       @id @default(cuid())
  reporterId   String
  targetType   ReportTarget
  targetId     String
  reason       String
  createdAt    DateTime     @default(now())
  // Moderation review state (null = still open/unactioned)
  resolvedAt   DateTime?
  resolvedById String?
  resolution   String?      // "hide" | "delete" | "dismiss"
  reporter     User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([resolvedAt])
}

model BlockedUser {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("BlockerRelation", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlockedRelation", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
}

enum ReportTarget {
  POST
  COMMENT
  USER
}
